# Copy to .env.local and fill with values from your Supabase project dashboard.
# Use the dev project for local development and Vercel Preview; use the prod project for Vercel Production.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Playwright `e2e/cloud.spec.ts` — set `E2E_CLOUD=1` when running that file so the dev server keeps Supabase env (see playwright.config.ts). Also set an existing account:
# E2E_SUPABASE_EMAIL=
# E2E_SUPABASE_PASSWORD=
